{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "默认权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-read-file",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "path": "**" }]
    }
  ]
}
