        }
      },
>>>>>>> theirs
      "allow_manual": true
    },
    {
      "key": "lawyers",
      "label": "代理律师",
      "type": "party",
      "required": true,
      "visibility": "value_only",
      "multiple": true,
      "min": 1,
      "separator": "、",
      "separator_drop_underline": true,
      "value_suffix": "律师",
      "dict_source": "lawyers",
      "remember_history": true,
      "default_role": "代理律师"
