    {
      "key": "plaintiffs",
      "label": "原告",
      "type": "party",
      "required": true,
      "visibility": "full",
      "multiple": true,
      "min": 1,
      "separator": "、",
      "separator_drop_underline": true,
      "dict_source": "parties",
      "remember_history": true,
      "default_role": "原告"
    },
    {
      "key": "defendants",
      "label": "被告",
      "type": "party",
      "required": true,
      "visibility": "full",
      "multiple": true,
      "min": 1,
      "separator": "、",
      "separator_drop_underline": true,
      "dict_source": "parties",
      "remember_history": true,
      "default_role": "被告"
    },
    {
      "key": "third_parties",
      "label": "第三人",
      "type": "party",
      "required": false,
      "visibility": "auto",
      "multiple": true,
      "min": 0,
      "separator": "、",
      "separator_drop_underline": true,
      "dict_source": "parties",
      "hideable": true,
      "remember_history": true,
      "default_role": "第三人"
    },
    {
      "key": "cause",
      "label": "案由",
      "type": "select",
      "required": true,
      "visibility": "value_only",
      "dict_source": "causes",
      "remember_history": true
    },
    {
      "key": "case_no",
      "label": "案号",
      "type": "text",
      "required": false,
      "visibility": "auto",
      "hideable": true,
      "placeholder": "例如：（2026）京73行初6547号"
    },
    {
      "key": "client_name",
      "label": "委托人名称",
      "type": "reference",
      "required": true,
      "visibility": "value_only",
